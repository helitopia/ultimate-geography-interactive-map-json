{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "regions",
    "height",
    "width"
  ],
  "additionalProperties": false,
  "properties": {
    "commonTerritories": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "regions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/region"
      }
    },
    "height": {
      "type": "number",
      "minimum": 1
    },
    "width": {
      "type": "number",
      "minimum": 1
    }
  },
  "$defs": {
    "region": {
      "type": "object",
      "required": [
        "regionName",
        "areas"
      ],
      "additionalProperties": false,
      "properties": {
        "regionName": {
          "type": "string"
        },
        "areas": {
          "$ref": "#/$defs/areas"
        },
        "disputedRegions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/disputedRegion"
          },
          "minItems": 1
        }
      }
    },
    "areas": {
      "type": "object",
      "required": [
        "low-res",
        "medium-res",
        "high-res"
      ],
      "additionalProperties": false,
      "properties": {
        "low-res": {
          "$ref": "#/$defs/area"
        },
        "medium-res": {
          "$ref": "#/$defs/area"
        },
        "high-res": {
          "$ref": "#/$defs/area"
        }
      }
    },
    "area": {
      "type": "object",
      "required": [
        "areaWKT",
        "sourceMetadata"
      ],
      "additionalProperties": false,
      "properties": {
        "areaWKT": {
          "type": "string"
        },
        "sourceMetadata": {
          "type": "object",
          "required": ["sourceType"],
          "additionalProperties": false,
          "properties": {
            "sourceType": {
              "type": "string"
            }
          },
          "if": {
            "properties": {
              "sourceType": {
                "const": "Natural Earth"
              }
            }
          },
          "then": {
            "$ref": "#/$defs/naturalEarthMetadata"
          },
          "else": {
            "type": "object"
          }
        }
      }
    },
    "naturalEarthMetadata": {
      "required": [
        "sourceUrl",
        "layerName",
        "entityIdentifier"
      ],
      "properties": {
        "sourceUrl": {
          "type": "string"
        },
        "layerName": {
          "type": "string"
        },
        "entityIdentifier": {
          "type": "string",
          "pattern": "^\\w+=\\w+$"
        },
        "remark": {
          "type": "string"
        }
      }
    },
    "disputedRegion": {
      "type": "object",
      "required": [
        "controlType",
        "areaReference"
      ],
      "additionalProperties": false,
      "properties": {
        "controlType": {
          "type": "string",
          "enum": [
            "CONTROLLED",
            "CLAIMED"
          ]
        },
        "areaReference": {
          "type": "object",
          "required": [
            "referenceType",
            "referenceId"
          ],
          "additionalProperties": false,
          "properties": {
            "referenceType": {
              "type": "string",
              "enum": [
                "regionReference",
                "territoryReference"
              ]
            },
            "referenceId": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}